# ─── AI Provider ─────────────────────────────────────────────────────────────
# Choose one: "anthropic" (default) or "openai"
AI_PROVIDER=anthropic

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — only needed if AI_PROVIDER=openai (npm install openai separately)
# OPENAI_API_KEY=sk-...

# ─── Google Maps Platform ────────────────────────────────────────────────────
# Client key — exposed in browser bundle. Restrict to Maps JS API + Places only.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Server key (optional) — used for Geocoding + Directions API calls server-side.
# If not set, falls back to the public key above.
# Restrict this key by IP in Google Cloud Console for best security.
# GOOGLE_MAPS_SERVER_KEY=your-server-only-key
