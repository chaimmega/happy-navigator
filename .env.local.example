# ─── AI Provider ─────────────────────────────────────────────────────────────
# Choose one: "anthropic" (default) or "openai"
AI_PROVIDER=anthropic

# Anthropic (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — only needed if AI_PROVIDER=openai (npm install openai separately)
# OPENAI_API_KEY=sk-...
